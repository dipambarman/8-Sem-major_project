{
  "cli": {
    "version": ">= 5.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "http://localhost:3000",
        "EXPO_PUBLIC_SOCKET_URL": "ws://localhost:3000"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api-staging.smartcanteen.com",
        "EXPO_PUBLIC_SOCKET_URL": "wss://api-staging.smartcanteen.com"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.smartcanteen.com",
        "EXPO_PUBLIC_SOCKET_URL": "wss://api.smartcanteen.com"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
